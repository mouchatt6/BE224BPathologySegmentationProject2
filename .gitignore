# ---- Submission CSVs: cataloged locally by model + iteration, never pushed ----
# Leading slash anchors to repo root so only the top-level folder matches.
/submissions/

# ---- Data (never commit raw images or labels) ----
# Leading slash is REQUIRED: a bare "data/" also matches src/data/ and would
# silently exclude the data-pipeline package. "/data/" matches only the top-level
# symlink folder.
/data/
*.png
*.jpg
*.jpeg
*.tif
*.tiff

# ---- Python virtual environment ----
.venv/
venv/
env/

# ---- Local-only planning / context docs (kept out of the public repo) ----
prostate_pathology_action_plan.md
*orientation*.md

# ---- Caches / build ----
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.DS_Store

# ---- Cached arrays: never commit binary feature/prediction dumps ----
*.npy
*.npz

# ---- Outputs: keep folder structure (.gitkeep) but ignore heavy artifacts ----
outputs/checkpoints/*
# features/, features_v2/, and any future feature cache dir
outputs/features*/
outputs/oof_preds/*
outputs/submissions/*
outputs/logs/*
outputs/figures/*
outputs/folds.csv
!outputs/**/.gitkeep

# Allow YAML configs and code through
!configs/
!src/
!scripts/
